<Window x:Class="Master_floor.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История продаж" Height="400" Width="650">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="tbPartner" Grid.Row="0" Margin="0,0,0,10"/>
        <DataGrid x:Name="dgSales" Grid.Row="1" AutoGenerateColumns="True"/>
    </Grid>
</Window>