<Window x:Class="Master_floor.PartnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Партнер" Height="380" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Content="Тип партнера:" Grid.Row="0" Margin="0,5,0,0"/>
        <ComboBox x:Name="cmbType" Grid.Row="1" Margin="0,0,0,10" Height="25">
            <ComboBoxItem>ЗАО</ComboBoxItem>
            <ComboBoxItem>ООО</ComboBoxItem>
            <ComboBoxItem>ПАО</ComboBoxItem>
            <ComboBoxItem>ОАО</ComboBoxItem>
        </ComboBox>

        <Label Content="Наименование:" Grid.Row="2" Margin="0,5,0,0"/>
        <TextBox x:Name="txtName" Grid.Row="3" Margin="0,0,0,10" Height="25"/>

        <Label Content="Директор:" Grid.Row="4" Margin="0,5,0,0"/>
        <TextBox x:Name="txtDirector" Grid.Row="5" Margin="0,0,0,10" Height="25"/>

        <Label Content="Телефон:" Grid.Row="6" Margin="0,5,0,0"/>
        <TextBox x:Name="txtPhone" Grid.Row="7" Margin="0,0,0,10" Height="25"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" Width="80" Height="30" Margin="5" Click="BtnOk_Click"/>
            <Button Content="Отмена" Width="80" Height="30" Margin="5" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>